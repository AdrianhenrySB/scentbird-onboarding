# ── Jira ─────────────────────────────────────────────────────────────────────
# Your Atlassian domain (just the subdomain part)
JIRA_DOMAIN=scentbird.atlassian.net

# Email address of the Jira SERVICE ACCOUNT (not your personal account)
# IMPORTANT: This must be a dedicated service account, NOT subject to SSO/SAML.
# See SETUP.md Step 4 for how to create it.
JIRA_EMAIL=it-automation@scentbird.com

# API token generated from the service account at:
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_api_token_here

# ── Slack (optional) ──────────────────────────────────────────────────────────
# Incoming Webhook URL for posting to #it-onboarding
# Create one at: https://api.slack.com/apps → Your App → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/xxxx

# ── App ───────────────────────────────────────────────────────────────────────
# Your deployed Vercel URL (set automatically by Vercel, override if using custom domain)
BASE_URL=https://your-project.vercel.app
